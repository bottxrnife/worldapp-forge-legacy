# ── DappDock credentials ────────────────────────────────────────────────────
# Copy to `.env`, fill in, then restart `npx expo start -c`.
# Every integration degrades gracefully: with no keys the app still runs with
# simulated verification/publishing and template-mode drafting.

# 1) The design agent (LLM with tool calling)
# Primary: console.anthropic.com API key (direct Messages API).
EXPO_PUBLIC_ANTHROPIC_API_KEY=
# Optional override (defaults to claude-sonnet-4-6)
EXPO_PUBLIC_ANTHROPIC_MODEL=
# Fallback when no API key: local FastAPI proxy backed by Claude Code subscription.
# Start: ~/Documents/GitHub/dappdock-claude-proxy/scripts/start.sh (PROXY_HOST=0.0.0.0)
# Use your Mac LAN IP so Expo Go on a phone can reach it.
# EXPO_PUBLIC_ANTHROPIC_PROXY_URL=http://192.168.x.x:3456/v1/messages
# Optional when the proxy sets PROXY_API_KEY (defaults to "dummy")
# EXPO_PUBLIC_ANTHROPIC_PROXY_KEY=dummy

# 2) World ID 4.0 — developer.world.org → create an app + an action, and (4.0)
#    mint an RP + signing key. Verification deep-links into World App via the
#    Wallet Bridge, then the proof is validated against the v4 verify endpoint.
#    NOTE (World Track B): proof validation must happen in a backend or smart
#    contract — set EXPO_PUBLIC_WORLD_VERIFY_URL to YOUR backend for the prize
#    (it forwards the proof to World / verifies on-chain + enforces a UNIQUE
#    (action, nullifier) constraint). The default hits the cloud verifier so the
#    demo works without a server.
EXPO_PUBLIC_WORLD_APP_ID=
EXPO_PUBLIC_WORLD_RP_ID=
EXPO_PUBLIC_WORLD_ACTION=verify-human
# "production" for real devices, "staging" for the World App simulator (must
# match the action's environment — the #1 World ID debugging trap).
EXPO_PUBLIC_WORLD_ENV=production
# Override to point proof validation at your own backend / verifier:
# EXPO_PUBLIC_WORLD_VERIFY_URL=https://your-backend.example.com/api/verify-world
# Optional: Developer Portal team API key (api_…) for Cursor MCP — Settings → API keys
# Enables world-developer-portal MCP tools (create/configure World ID apps from the agent).
WORLD_DEVELOPER_API_KEY=

# 3) LI.FI + Composer — portal.li.fi → API key (the API is open; a key only
#    raises rate limits). Cross-chain routing AND Composer (swap+deposit to a
#    vault in one tx) run through the same REST base below.
EXPO_PUBLIC_LIFI_API_KEY=
EXPO_PUBLIC_LIFI_INTEGRATOR=dappdock
# REST base for /quote + /status (default LI.FI production). The ETHGlobal NY
# 2026 hackathon Composer SDK host is https://ethglobal-composer.li.quest.
# EXPO_PUBLIC_LIFI_API_URL=https://li.quest/v1

# 4) ENS — pure ENS via viem, no third-party subname service (sponsor track is
#    ENS itself). Resolution, reverse/primary names, ENSIP-5 text records,
#    ENSIP-12 avatars, and ENSIP-26 agent records (`agent-context`,
#    `agent-endpoint[<protocol>]`) all resolve from L1 mainnet through the
#    Universal Resolver — no API key required. ENS_DOMAIN is the namespace for
#    dapp / agent identities (e.g. label.<domain>, assistant.agent.<domain>).
#    Loyalty punch cards are read from each user's `dappdock.loyalty` text record
#    on their primary ENS name (set it in any ENS manager); without one the local
#    device cache is the source of truth.
EXPO_PUBLIC_ENS_DOMAIN=dappdock.eth

# Mainnet RPC for ENS resolution + loyalty/agent text-record reads (default: public node)
EXPO_PUBLIC_ETH_RPC_URL=
