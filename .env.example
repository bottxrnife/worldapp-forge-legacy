# Forge — World App Mini App. Copy to `.env` and fill in. The app runs in a
# degraded/simulated mode where a credential is missing.

# ── Design agent (server-side only; the client calls /api/agent) ──
# Primary: an Anthropic API key. Fallback: a local Claude Code proxy (LAN IP so
# World App on a phone can reach your machine).
ANTHROPIC_API_KEY=
ANTHROPIC_PROXY_URL=
ANTHROPIC_PROXY_KEY=dummy
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── World ID 4.0 — developer.world.org (create an app + action, mint an RP) ──
NEXT_PUBLIC_WORLD_APP_ID=app_...
NEXT_PUBLIC_WORLD_ACTION=verify-human
NEXT_PUBLIC_WORLD_ENV=production
WORLD_RP_ID=rp_...
# RP signing key — SERVER ONLY, never a NEXT_PUBLIC_ var, never logged.
WORLD_SIGNER_PRIVATE_KEY=
WORLD_SIGNER_ADDRESS=

# ── ENS — the namespace for created apps (label.<domain>) + the agent identity ──
NEXT_PUBLIC_ENS_DOMAIN=forge.eth
# Mainnet RPC for ENS resolution / record reads (default: a public node)
ETH_RPC_URL=

# ── Walrus — decentralized storage (testnet publisher/aggregator by default) ──
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
