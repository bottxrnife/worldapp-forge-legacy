# ── DappDock credentials ────────────────────────────────────────────────────
# Copy to `.env`, fill in, then restart `npx expo start -c`.
# Every integration degrades gracefully: with no keys the app still runs with
# simulated verification/publishing and template-mode drafting.

# 1) The design agent (LLM with tool calling) — console.anthropic.com
EXPO_PUBLIC_ANTHROPIC_API_KEY=
# Optional override (defaults to claude-sonnet-4-5)
EXPO_PUBLIC_ANTHROPIC_MODEL=

# 2) World — developer.world.org → create an app + an incognito action.
#    Verification deep-links into World App on the same phone via the Wallet
#    Bridge, then the proof is checked against the Developer Portal.
EXPO_PUBLIC_WORLD_APP_ID=
EXPO_PUBLIC_WORLD_ACTION=verify-human
# Optional: Developer Portal team API key (api_…) for Cursor MCP — Settings → API keys
# Enables world-developer-portal MCP tools (create/configure World ID apps from the agent).
WORLD_DEVELOPER_API_KEY=

# 3) LI.FI — portal.li.fi → API key (quotes also work without one, rate-limited)
EXPO_PUBLIC_LIFI_API_KEY=
EXPO_PUBLIC_LIFI_INTEGRATOR=dappdock

# 4) ENS — pure ENS via viem, no third-party subname service (sponsor track is
#    ENS itself). Resolution, reverse/primary names, ENSIP-5 text records,
#    ENSIP-12 avatars, and ENSIP-26 agent records (`agent-context`,
#    `agent-endpoint[<protocol>]`) all resolve from L1 mainnet through the
#    Universal Resolver — no API key required. ENS_DOMAIN is the namespace for
#    dapp / agent identities (e.g. label.<domain>, assistant.agent.<domain>).
#    Loyalty punch cards are read from each user's `dappdock.loyalty` text record
#    on their primary ENS name (set it in any ENS manager); without one the local
#    device cache is the source of truth.
EXPO_PUBLIC_ENS_DOMAIN=dappdock.eth

# Mainnet RPC for ENS resolution + loyalty/agent text-record reads (default: public node)
EXPO_PUBLIC_ETH_RPC_URL=
